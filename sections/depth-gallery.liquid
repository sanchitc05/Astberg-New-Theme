      updatePlaneVisibility(camera.position.z);
      updatePlaneMotion(scrollObj);

      /* Label */
      updateLabel(camera);

      /* Background */
      var moodBlend = getMoodBlendData(camera.position.z);
      if (moodBlend) bgSetMoodBlend(moodBlend);
      var depthProg  = getDepthProgress(camera.position.z);
      var bd2 = getPlaneBlendData(camera.position.z);
      var blend2 = bd2 ? bd2.blend : 0;
      var distFromCenter = Math.abs(blend2 - 0.5) * 2;
