    }

    /* ── Resize ─────────────────────────────────────────────────── */
    function resize() {
      var w = canvas.clientWidth  || window.innerWidth  || 1;
      var h = canvas.clientHeight || window.innerHeight || 1;
      if (w <= 0 || h <= 0) return;
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h, false);
