    }

    function loop() {
      if (!isRunning) return;
      rafId = requestAnimationFrame(loop);
      var time = performance.now();
      var progress = readScrollProgress();

      /* Smooth camera toward target Z */
      var targetZ = maxCameraZ - progress * (maxCameraZ - minCameraZ);
      camera.position.z = lerp(camera.position.z, targetZ, 0.08);

      /* Velocity signal */
      var rawVel = (camera.position.z - prevCameraZ) * 60;
      velocity = lerp(velocity, rawVel, 0.12);
      velocity = clamp(velocity, -velocityMax, velocityMax);
      if (Math.abs(velocity) < 0.0001) velocity = 0;
      prevCameraZ = camera.position.z;

      var scrollObj = { velocity: velocity, velocityMax: velocityMax, maxCameraZ: maxCameraZ, minCameraZ: minCameraZ };

