    var rafId = null, isRunning = false, initialized = false, sectionVisible = false;
    var prevCameraZ = camera.position.z, velocity = 0, velocityMax = 1.5;

    function startLoop() {
      if (isRunning) return;
      isRunning = true;
      prevCameraZ = camera.position.z;
