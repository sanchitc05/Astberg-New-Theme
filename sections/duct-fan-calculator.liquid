    <!-- CARD HEADER -->
    <div class="asc-hd-{{ sid }}">
      <div class="asc-hd-top">
        <div class="asc-hd-logo">
          {%- if section.settings.logo_image != blank -%}
            <img src="{{ section.settings.logo_image | image_url: width: 200 }}" alt="{{ section.settings.logo_image.alt | default: 'Astberg' }}">
          {%- else -%}
            <img src="https://www.astbergventilation.com/images/logo.webp" alt="Astberg Ventilation" onerror="this.style.display='none'">
          {%- endif -%}
        </div>
        <button class="asc-xbtn" id="asc-close-{{ sid }}" aria-label="Close calculator">✕</button>
      </div>
      <h2 class="asc-hd-title">{{ section.settings.heading | default: 'Duct Fan Size Calculator' }}</h2>
      <p class="asc-hd-sub">{{ section.settings.subheading | default: 'Find the perfect ventilation solution for your space' }}</p>
      <div class="asc-stepdots">
        <div class="asc-stepdot asc-on" id="asc-dot1-{{ sid }}"></div>
        <div class="asc-stepdot" id="asc-dot2-{{ sid }}"></div>
      </div>
    </div>

    <!-- CARD BODY -->
    <div class="asc-body-{{ sid }}">

      <!-- STEP 1: INPUTS -->
      <div class="asc-panel" id="asc-p1-{{ sid }}">

        <span class="asc-lbl">Unit of Measurement</span>
        <div class="asc-pills" id="asc-pills-{{ sid }}">
          <button class="asc-pill asc-on" data-unit="feet">Feet</button>
          <button class="asc-pill" data-unit="meter">Meter</button>
          <button class="asc-pill" data-unit="centimeter">Cm</button>
          <button class="asc-pill" data-unit="inches">Inch</button>
          <button class="asc-pill" data-unit="mm">Mm</button>
        </div>

        <span class="asc-dimlbl" id="asc-dimlbl-{{ sid }}">Room Dimensions (feet)</span>
        <div class="asc-dims">
          <div class="asc-field">
            <div class="asc-field-label">L</div>
            <input class="asc-numinput" id="asc-l-{{ sid }}" type="number" min="0" step="0.1" placeholder="0">
          </div>
          <span class="asc-dimsep">×</span>
          <div class="asc-field">
            <div class="asc-field-label">W</div>
            <input class="asc-numinput" id="asc-w-{{ sid }}" type="number" min="0" step="0.1" placeholder="0">
          </div>
          <span class="asc-dimsep">×</span>
          <div class="asc-field">
            <div class="asc-field-label">H</div>
            <input class="asc-numinput" id="asc-h-{{ sid }}" type="number" min="0" step="0.1" placeholder="0">
          </div>
        </div>

        <span class="asc-lbl">Air Changes Per Hour (ACPH)</span>
        <div class="asc-acphrow">
          <input class="asc-acphinput" id="asc-acph-{{ sid }}" type="number" min="0" step="0.1" placeholder="Type or pick room type →">
          <button class="asc-roombtn" id="asc-room-open-{{ sid }}">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            Room Type
          </button>
        </div>

        <button class="asc-calcbtn" id="asc-calcbtn-{{ sid }}">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 7H7a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2V9a2 2 0 00-2-2h-2M9 7V5a2 2 0 012-2h2a2 2 0 012 2v2M9 7h6M12 11v6M9 14h6"/></svg>
          Calculate CMH &amp; CFM
        </button>

        <div class="asc-tncrow">
          <button class="asc-tncbtn" id="asc-tnc-open-{{ sid }}">Terms &amp; Conditions</button>
        </div>

      </div>

      <!-- STEP 2: RESULTS -->
      <div class="asc-panel asc-hide" id="asc-p2-{{ sid }}">

        <div class="asc-rboxes">
          <div class="asc-rbox">
            <div class="asc-rbox-unit">CMH</div>
            <div class="asc-rbox-val" id="asc-cmh-{{ sid }}">—</div>
            <div class="asc-rbox-desc">m³ per hour</div>
          </div>
          <div class="asc-rbox">
            <div class="asc-rbox-unit">CFM</div>
            <div class="asc-rbox-val" id="asc-cfm-{{ sid }}">—</div>
            <div class="asc-rbox-desc">ft³ per minute</div>
          </div>
        </div>

        <div class="asc-prodhead">
          <span>Recommended Products</span>
          <div class="asc-prodline"></div>
        </div>

        <div class="asc-tagwrap asc-hide" id="asc-tagwrap-{{ sid }}">
          <div class="asc-tagrow" id="asc-tagrow-{{ sid }}"></div>
        </div>

        <div class="asc-prodgrid" id="asc-prodgrid-{{ sid }}"></div>

        <button class="asc-recalcbtn" id="asc-recalc-{{ sid }}">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 102.13-9.36L1 10"/></svg>
          Recalculate
        </button>

      </div>

    </div><!-- /body -->
