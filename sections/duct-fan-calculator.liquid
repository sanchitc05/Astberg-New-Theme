</div><!-- /overlay -->

{%- if section.settings.show_fab != false -%}
<!-- ── FLOATING ACTION BUTTON ────────────────────────────── -->
<div class="asc-fabwrap-{{ sid }}" id="asc-fabwrap-{{ sid }}">
  <button class="asc-fab-{{ sid }}" id="asc-fab-{{ sid }}" aria-label="{{ section.settings.fab_label | default: 'Fan Size Calculator' }}">
    <span class="asc-fab-tip-{{ sid }}">{{ section.settings.fab_label | default: 'Fan Calculator' }}</span>
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/>
    </svg>
    <span class="asc-fab-x-{{ sid }}" id="asc-fab-x-{{ sid }}" role="button" aria-label="Hide calculator button" tabindex="0">✕</span>
  </button>
</div>
{%- endif -%}

<script>
(function () {
  'use strict';

  var SID       = '{{ sid }}';
  var KEY       = SID.replace(/-/g,'_');
  var FANS      = window['ascFans_' + KEY] || [];
  var TAGS      = window['ascTags_' + KEY] || [];
  /* Share fan data with the global FAB on every page via localStorage */
  try {
    if (FANS.length) localStorage.setItem('ascg-fans', JSON.stringify(FANS));
    if (TAGS.length) localStorage.setItem('ascg-tags', JSON.stringify(TAGS));
  } catch(e) {}

  var UNIT_TO_FEET = { feet:1, meter:3.28084, centimeter:0.0328084, inches:0.0833333, mm:0.00328084 };
  var UNIT_NAME    = { feet:'feet', meter:'meters', centimeter:'centimeters', inches:'inches', mm:'millimeters' };

  function el(id) { return document.getElementById(id + '-' + SID); }

  var overlay   = el('asc-overlay');
  var openBtn   = el('asc-open');
  var closeBtn  = el('asc-close');
  var sheetBg   = el('asc-sheetbg');
  var roomOpen  = el('asc-room-open');
  var tncWrap   = el('asc-tnc');
  var tncOpen   = el('asc-tnc-open');
  var tncClose  = el('asc-tnc-close');
  var p1        = el('asc-p1');
  var p2        = el('asc-p2');
  var dot1      = el('asc-dot1');
  var dot2      = el('asc-dot2');
  var dimLbl    = el('asc-dimlbl');
  var cmhEl     = el('asc-cmh');
  var cfmEl     = el('asc-cfm');
  var prodGrid  = el('asc-prodgrid');
  var tagWrap   = el('asc-tagwrap');
  var tagRow    = el('asc-tagrow');
  var pillsWrap = el('asc-pills');
  var calcBtn   = el('asc-calcbtn');
  var recalcBtn = el('asc-recalc');

  var activeUnit = 'feet';
  var currentMatchedFans = [];
  var activeTag = 'all';

  /* ── open / close ── */
  if (openBtn) {
    openBtn.addEventListener('click', function () {
      overlay.classList.add('asc-on');
      document.body.style.overflow = 'hidden';
    });
  }
  function closeAll() {
    overlay.classList.remove('asc-on');
    document.body.style.overflow = '';
  }
  closeBtn.addEventListener('click', closeAll);
  overlay.addEventListener('click', function (e) { if (e.target === overlay) closeAll(); });
  document.addEventListener('keydown', function (e) {
    if (e.key !== 'Escape') return;
    if (sheetBg.classList.contains('asc-on')) { sheetBg.classList.remove('asc-on'); }
    else if (tncWrap.classList.contains('asc-on')) { tncWrap.classList.remove('asc-on'); }
    else { closeAll(); }
  });

  /* ── unit pills ── */
  pillsWrap.querySelectorAll('.asc-pill').forEach(function (pill) {
    pill.addEventListener('click', function () {
      pillsWrap.querySelectorAll('.asc-pill').forEach(function (p) { p.classList.remove('asc-on'); });
      pill.classList.add('asc-on');
      activeUnit = pill.dataset.unit;
      dimLbl.textContent = 'Room Dimensions (' + UNIT_NAME[activeUnit] + ')';
    });
  });

  /* ── room sheet ── */
  roomOpen.addEventListener('click', function () { sheetBg.classList.add('asc-on'); });
  sheetBg.addEventListener('click', function (e) { if (e.target === sheetBg) sheetBg.classList.remove('asc-on'); });
  sheetBg.querySelectorAll('.asc-rcard').forEach(function (card) {
    card.addEventListener('click', function () {
      el('asc-acph').value = card.dataset.acph;
      sheetBg.classList.remove('asc-on');
    });
  });

  /* ── T&C ── */
  tncOpen.addEventListener('click', function () { tncWrap.classList.add('asc-on'); });
  tncClose.addEventListener('click', function () { tncWrap.classList.remove('asc-on'); });

  /* ── calculate ── */
  calcBtn.addEventListener('click', function () {
    var l  = parseFloat(el('asc-l').value);
    var w  = parseFloat(el('asc-w').value);
    var h  = parseFloat(el('asc-h').value);
    var ac = parseFloat(el('asc-acph').value);

    if ([l, w, h, ac].some(function (v) { return isNaN(v) || v <= 0; })) {
      alert('Please fill in all four fields with valid positive numbers.');
      return;
    }

    var f   = UNIT_TO_FEET[activeUnit] || 1;
    var cfm = (l * f) * (w * f) * (h * f) * ac / 60;
    var cmh = cfm * 1.7;

    p1.classList.add('asc-hide');
    p2.classList.remove('asc-hide');
    dot1.classList.remove('asc-on');
    dot2.classList.add('asc-on');
    overlay.scrollTop = 0;

    countUp(cmhEl, cmh, 650);
    countUp(cfmEl, cfm, 650);
    renderProducts(cmh);
  });

  /* ── recalculate ── */
  recalcBtn.addEventListener('click', function () {
    p2.classList.add('asc-hide');
    p1.classList.remove('asc-hide');
    dot2.classList.remove('asc-on');
    dot1.classList.add('asc-on');
  });

  /* ── count-up animation ── */
  function countUp(target, end, duration) {
    var start = null;
    function step(ts) {
      if (!start) start = ts;
      var progress = Math.min((ts - start) / duration, 1);
      var eased = 1 - Math.pow(1 - progress, 3);
      target.textContent = (eased * end).toFixed(2);
      if (progress < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  /* ── parse tags helper ── */
  function parseTags(raw) {
    return (raw || '').split(',').map(function (t) { return t.trim().toLowerCase(); }).filter(Boolean);
  }

  /* ── render products (entry point) ── */
  function renderProducts(cmh) {
    currentMatchedFans = FANS.filter(function (f) { return cmh >= f.minCmh && cmh <= f.maxCmh; });
    activeTag = 'all';
    renderTagFilters();
    renderProductGrid();
  }

  /* ── render tag filter pills ── */
  function renderTagFilters() {
    var usedValues = {};
    currentMatchedFans.forEach(function (f) {
      parseTags(f.tags).forEach(function (t) { usedValues[t] = true; });
    });

    var presentTags = TAGS.filter(function (t) { return usedValues[t.value]; });

    if (!presentTags.length) {
      tagWrap.classList.add('asc-hide');
      return;
    }
    tagWrap.classList.remove('asc-hide');

    tagRow.innerHTML = '<button class="asc-tagpill' + (activeTag === 'all' ? ' asc-on' : '') + '" data-tag="all">All</button>'
      + presentTags.map(function (t) {
          return '<button class="asc-tagpill' + (activeTag === t.value ? ' asc-on' : '') + '" data-tag="' + t.value + '">' + escHtml(t.label) + '</button>';
        }).join('');

    tagRow.querySelectorAll('.asc-tagpill').forEach(function (pill) {
      pill.addEventListener('click', function () {
        activeTag = pill.dataset.tag;
        renderTagFilters();
        renderProductGrid();
      });
    });
  }

  /* ── render product grid (respects activeTag) ── */
  function renderProductGrid() {
    var toShow = activeTag === 'all'
      ? currentMatchedFans
      : currentMatchedFans.filter(function (f) { return parseTags(f.tags).indexOf(activeTag) !== -1; });

    if (!toShow.length && currentMatchedFans.length) {
      prodGrid.innerHTML = '<div class="asc-noprod">'
        + '<svg width="38" height="38" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>'
        + '<p>No products found for this filter.</p>'
        + '</div>';
      return;
    }

    if (!toShow.length) {
      prodGrid.innerHTML = '<div class="asc-noprod">'
        + '<svg width="38" height="38" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>'
        + '<p>No products match this CMH range.<br>Add fan products in the theme editor and set their CMH range.</p>'
        + '</div>';
      return;
    }

    prodGrid.innerHTML = toShow.map(function (fan) {
      var badge = fan.badge ? '<span class="asc-pbadge">' + fan.badge + '</span>' : '';
      var img = fan.image
        ? '<img class="asc-pimg" src="' + fan.image + '" alt="' + escHtml(fan.name) + '" loading="lazy">'
        : '<div class="asc-pimg-ph"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div>';
      var cta = fan.url ? '<span class="asc-pshop">Shop Now <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>' : '';
      var tag = fan.url ? 'a' : 'div';
      var attr = fan.url ? 'href="' + fan.url + '" target="_blank" rel="noopener noreferrer"' : '';
      return '<' + tag + ' class="asc-pcard" ' + attr + '>'
        + badge + img
        + '<div class="asc-pname">' + escHtml(fan.name) + '</div>'
        + cta + '</' + tag + '>';
    }).join('');
  }

  function escHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  /* ── floating action button ───────────────────────────── */
  var fabWrap = document.getElementById('asc-fabwrap-' + SID);
  if (fabWrap) {
    var fabBtn   = document.getElementById('asc-fab-' + SID);
    var fabXBtn  = document.getElementById('asc-fab-x-' + SID);

    var fabOffX = 0, fabOffY = 0;
    var fabDragSX, fabDragSY, fabDragSOX, fabDragSOY;
    var fabDragging = false;
    var fabDidMove  = false;

    function fabClient(e) { return e.touches ? e.touches[0] : e; }

    fabWrap.addEventListener('mousedown',  fabDown);
    fabWrap.addEventListener('touchstart', fabDown, { passive: false });

    function fabDown(e) {
      if (e.target === fabXBtn || fabXBtn.contains(e.target)) return;
      fabDragging = true;
      fabDidMove  = false;
      var c = fabClient(e);
      fabDragSX  = c.clientX;
      fabDragSY  = c.clientY;
      fabDragSOX = fabOffX;
      fabDragSOY = fabOffY;
      fabWrap.classList.add('asc-fab-dragging');
      e.preventDefault();
    }

    document.addEventListener('mousemove',  fabMove);
    document.addEventListener('touchmove',  fabMove, { passive: false });

    function fabMove(e) {
      if (!fabDragging) return;
      var c  = fabClient(e);
      var dx = c.clientX - fabDragSX;
      var dy = c.clientY - fabDragSY;
      if (Math.abs(dx) > 4 || Math.abs(dy) > 4) fabDidMove = true;
      fabOffX = fabDragSOX + dx;
      fabOffY = fabDragSOY + dy;
      fabWrap.style.transform = 'translate(' + fabOffX + 'px, ' + fabOffY + 'px)';
      e.preventDefault();
    }

    document.addEventListener('mouseup',  fabUp);
    document.addEventListener('touchend', fabUp);

    function fabUp() {
      if (!fabDragging) return;
      fabDragging = false;
      fabWrap.classList.remove('asc-fab-dragging');
    }

    function openFromFab() {
      overlay.classList.add('asc-on');
      document.body.style.overflow = 'hidden';
    }
    fabBtn.addEventListener('click', function () {
      if (fabDidMove) { fabDidMove = false; return; }
      openFromFab();
    });
    /* touchstart preventDefault (needed for drag) cancels the click event on mobile.
       Handle tap via touchend instead. */
    fabBtn.addEventListener('touchend', function (e) {
      if (fabDidMove) { fabDidMove = false; return; }
      if (e.target === fabXBtn || fabXBtn.contains(e.target)) return;
      e.preventDefault();
      openFromFab();
    });

    fabXBtn.addEventListener('click', function (e) {
      e.stopPropagation();
      fabWrap.classList.add('asc-fab-gone');
    });
    fabXBtn.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); fabXBtn.click(); }
    });
  }

})();
</script>

