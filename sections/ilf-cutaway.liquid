<div id="IlfCutaway-{{ section.id }}">
  <section class="ict-section">
    <div class="ict-container">

      {% if section.settings.eyebrow != blank %}
        <p class="ict-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="ict-heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.description != blank %}
        <p class="ict-lead">{{ section.settings.description }}</p>
      {% endif %}

      {% if section.blocks.size > 0 %}
        <div class="ict-grid">

          <!-- ── Left: fan diagram + hotspots ── -->
          <div class="ict-stage">
            <div class="ict-svg-wrap">
              <svg viewBox="0 0 600 420" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:100%;display:block">
                <!-- outer frame -->
                <rect x="22" y="34" width="556" height="352" rx="20" fill="rgba(255,255,255,.025)" stroke="rgba(255,255,255,.14)" stroke-width="1.5"/>
                <rect x="40" y="52" width="520" height="316" rx="12" stroke="rgba(255,255,255,.06)" stroke-width="1"/>

                <!-- cylindrical housing (sectioned) -->
                <rect x="120" y="150" width="372" height="130" rx="16" fill="rgba(255,255,255,.04)" stroke="rgba(255,255,255,.2)" stroke-width="1.5"/>
                <rect x="120" y="150" width="372" height="130" rx="16" fill="none" stroke="rgba(255,255,255,.08)" stroke-width="1" transform="translate(0 6)"/>

                <!-- intake duct spigot (left) -->
                <path d="M44 178 H120 M44 252 H120" stroke="rgba(255,255,255,.18)" stroke-width="1.5"/>
                <ellipse cx="120" cy="215" rx="13" ry="65" fill="rgba(255,255,255,.03)" stroke="rgba(255,255,255,.18)" stroke-width="1.3"/>
                <!-- discharge duct spigot (right) -->
                <path d="M492 178 H556 M492 252 H556" stroke="rgba(255,255,255,.18)" stroke-width="1.5"/>
                <ellipse cx="556" cy="215" rx="11" ry="60" fill="rgba(255,255,255,.03)" stroke="rgba(255,255,255,.18)" stroke-width="1.3"/>

                <!-- impeller (1) -->
                <g transform="translate(215 215)">
                  <circle r="62" fill="rgba(0,178,107,.05)" stroke="rgba(167,244,50,.4)" stroke-width="1.3"/>
                  <g fill="rgba(167,244,50,.16)" stroke="rgba(167,244,50,.5)" stroke-width="1">
                    <path d="M0 -56 Q24 -22 0 0 Q-24 -22 0 -56Z"/>
                    <path d="M0 -56 Q24 -22 0 0 Q-24 -22 0 -56Z" transform="rotate(51)"/>
                    <path d="M0 -56 Q24 -22 0 0 Q-24 -22 0 -56Z" transform="rotate(102)"/>
                    <path d="M0 -56 Q24 -22 0 0 Q-24 -22 0 -56Z" transform="rotate(153)"/>
                    <path d="M0 -56 Q24 -22 0 0 Q-24 -22 0 -56Z" transform="rotate(204)"/>
                    <path d="M0 -56 Q24 -22 0 0 Q-24 -22 0 -56Z" transform="rotate(255)"/>
                    <path d="M0 -56 Q24 -22 0 0 Q-24 -22 0 -56Z" transform="rotate(306)"/>
                  </g>
                  <circle r="15" fill="rgba(255,255,255,.08)" stroke="rgba(255,255,255,.3)" stroke-width="1.2"/>
                  <circle r="5" fill="rgba(167,244,50,.6)"/>
                </g>

                <!-- EC motor (2) -->
                <g transform="translate(340 215)">
                  <rect x="-34" y="-38" width="68" height="76" rx="10" fill="rgba(255,255,255,.04)" stroke="rgba(255,255,255,.22)" stroke-width="1.3"/>
                  <circle r="24" stroke="rgba(0,178,107,.4)" stroke-width="1.2" fill="rgba(255,255,255,.02)"/>
                  <g stroke="rgba(255,255,255,.22)" stroke-width="1.4">
                    <path d="M0 -24 V24 M-24 0 H24"/>
                    <path d="M-17 -17 L17 17 M17 -17 L-17 17" opacity=".5"/>
                  </g>
                  <circle r="7" fill="rgba(255,255,255,.16)"/>
                </g>

                <!-- guide vanes (3) -->
                <g transform="translate(430 215)" stroke="rgba(255,255,255,.3)" stroke-width="1.6" stroke-linecap="round">
                  <path d="M-14 -44 Q6 -22 -10 0 Q6 22 -14 44"/>
                  <path d="M6 -44 Q26 -22 10 0 Q26 22 6 44"/>
                  <path d="M26 -44 Q46 -22 30 0 Q46 22 26 44"/>
                </g>

                <!-- terminal box (5) -->
                <g transform="translate(258 92)">
                  <rect width="92" height="44" rx="8" fill="rgba(255,255,255,.03)" stroke="rgba(255,255,255,.2)" stroke-width="1.3"/>
                  <rect x="12" y="11" width="30" height="14" rx="3" fill="rgba(0,178,107,.18)" stroke="rgba(167,244,50,.4)" stroke-width="1"/>
                  <circle cx="60" cy="16" r="3" fill="rgba(167,244,50,.6)"/>
                  <circle cx="72" cy="16" r="3" fill="rgba(255,255,255,.25)"/>
                  <path d="M12 33 H80 M12 39 H58" stroke="rgba(255,255,255,.25)" stroke-width="1.4" stroke-linecap="round"/>
                  <path d="M46 136 V44" stroke="rgba(255,255,255,.14)" stroke-width="1" transform="translate(0 -92)"/>
                </g>
                <path d="M304 136 V150" stroke="rgba(255,255,255,.18)" stroke-width="1.4"/>

                <!-- quick-release mounting foot (6) -->
                <g transform="translate(250 280)">
                  <path d="M-26 0 L-32 34 H32 L26 0Z" fill="rgba(255,255,255,.03)" stroke="rgba(255,255,255,.2)" stroke-width="1.3"/>
                  <rect x="-40" y="32" width="80" height="10" rx="3" fill="rgba(255,255,255,.05)" stroke="rgba(255,255,255,.2)" stroke-width="1"/>
                  <circle cx="-22" cy="37" r="2.6" fill="rgba(167,244,50,.5)"/>
                  <circle cx="22" cy="37" r="2.6" fill="rgba(167,244,50,.5)"/>
                </g>

                <!-- airflow path arrows -->
                <g fill="none" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M44 215 H150" stroke="#00B26B" stroke-width="2" opacity=".5"/>
                  <path d="M150 215 H170" stroke="#00B26B" stroke-width="2" opacity=".5" stroke-dasharray="5 4"/>
                  <path d="M470 215 H556" stroke="#A7F432" stroke-width="2" opacity=".55"/>
                  <path d="M132 200 l-10 -6 m10 6 l-10 6" stroke="#00B26B" stroke-width="2" opacity=".6"/>
                  <path d="M548 200 l10 -6 m-10 6 l10 6" stroke="#A7F432" stroke-width="2" opacity=".6"/>
                </g>
              </svg>

              <!-- hotspot positions match SVG viewBox 600×420 -->
              <button class="ict-hs active" data-i="0" style="left:35.8%;top:51.2%">1</button>
              <button class="ict-hs"        data-i="1" style="left:56.7%;top:51.2%">2</button>
              <button class="ict-hs"        data-i="2" style="left:71.7%;top:51.2%">3</button>
              <button class="ict-hs"        data-i="3" style="left:26%;top:39%">4</button>
              <button class="ict-hs"        data-i="4" style="left:50.7%;top:27.4%">5</button>
              <button class="ict-hs"        data-i="5" style="left:41.7%;top:76.6%">6</button>
            </div>
          </div>

          <!-- ── Right: component panel ── -->
          <div class="ict-info">
            <div class="ict-step">Component Detail</div>
            <div class="ict-panel">
              {% for block in section.blocks %}
                <div class="ict-comp{% if forloop.first %} show{% endif %}" {{ block.shopify_attributes }}>
                  <div class="ict-num">{{ block.settings.num }}</div>
                  <div class="ict-name">{{ block.settings.name }}</div>
                  <p class="ict-desc">{{ block.settings.desc }}</p>
                  <div class="ict-meta">
                    {% if block.settings.chip1 != blank %}<span>{{ block.settings.chip1 }}</span>{% endif %}
                    {% if block.settings.chip2 != blank %}<span>{{ block.settings.chip2 }}</span>{% endif %}
                    {% if block.settings.chip3 != blank %}<span>{{ block.settings.chip3 }}</span>{% endif %}
                  </div>
                </div>
              {% endfor %}
            </div>
            <div class="ict-nav">
              {% for block in section.blocks %}
                <button class="ict-dot{% if forloop.first %} active{% endif %}"
                        data-i="{{ forloop.index0 }}"
                        aria-label="{{ block.settings.name }}"></button>
              {% endfor %}
            </div>
          </div>

        </div>
      {% endif %}

    </div>
  </section>
</div>

{% stylesheet %}
/* ── Section ── */
#IlfCutaway-{{ section.id }} .ict-section {
  background: #111827;
  padding: 96px 0;
}
#IlfCutaway-{{ section.id }} *, #IlfCutaway-{{ section.id }} *::before, #IlfCutaway-{{ section.id }} *::after { box-sizing: border-box; }

/* ── Container ── */
#IlfCutaway-{{ section.id }} .ict-container {
  max-width: 1280px; margin: 0 auto; padding: 0 24px;
}

/* ── Header ── */
#IlfCutaway-{{ section.id }} .ict-eyebrow {
  font-size: 10px; font-weight: 600; letter-spacing: .14em;
  text-transform: uppercase; color: #A7F432; margin: 0 0 16px; line-height: 1;
}
#IlfCutaway-{{ section.id }} .ict-heading {
  font-size: clamp(30px, 4vw, 48px); font-weight: 700; line-height: 1.1;
  letter-spacing: -.025em; color: #fff; margin: 0 0 16px;
}
#IlfCutaway-{{ section.id }} .ict-lead {
  font-size: 16px; line-height: 1.7; color: rgba(255,255,255,.5); margin: 0;
  max-width: 640px;
}

/* ── Two-column grid ── */
#IlfCutaway-{{ section.id }} .ict-grid {
  display: grid;
  grid-template-columns: 1.45fr 1fr;
  gap: 50px;
  align-items: center;
  margin-top: 56px;
}

/* ── Left stage ── */
#IlfCutaway-{{ section.id }} .ict-stage {
  background: rgba(255,255,255,.03);
  border: 1px solid rgba(255,255,255,.08);
  border-radius: 24px;
  padding: 30px;
}

/* ── SVG wrapper (hotspots are absolute inside) ── */
#IlfCutaway-{{ section.id }} .ict-svg-wrap {
  position: relative;
}

/* ── Hotspot buttons ── */
#IlfCutaway-{{ section.id }} .ict-hs {
  position: absolute;
  width: 30px; height: 30px; border-radius: 50%;
  background: #A7F432; color: #111827; border: none; cursor: pointer;
  font-size: 13px; font-weight: 800; line-height: 1;
  display: flex; align-items: center; justify-content: center;
  transform: translate(-50%, -50%);
  transition: transform .2s;
  z-index: 4;
}
#IlfCutaway-{{ section.id }} .ict-hs::after {
  content: '';
  position: absolute; inset: -6px;
  border-radius: 50%;
  border: 1.5px solid rgba(167,244,50,.4);
  animation: ict-hsring-{{ section.id }} 2.4s ease-out infinite;
}
@keyframes ict-hsring-{{ section.id }} {
  0%   { transform: scale(.7); opacity: .9; }
  100% { transform: scale(1.7); opacity: 0; }
}
#IlfCutaway-{{ section.id }} .ict-hs:hover {
  transform: translate(-50%, -50%) scale(1.18);
}
#IlfCutaway-{{ section.id }} .ict-hs.active {
  background: #fff;
  transform: translate(-50%, -50%) scale(1.18);
}
#IlfCutaway-{{ section.id }} .ict-hs.active::after {
  border-color: rgba(255,255,255,.5);
}

/* ── Right info column ── */
#IlfCutaway-{{ section.id }} .ict-step {
  font-size: 11px; font-weight: 600; letter-spacing: .14em;
  text-transform: uppercase; color: #A7F432; margin-bottom: 14px;
}

/* ── Panel: component slots ── */
#IlfCutaway-{{ section.id }} .ict-panel { min-height: 220px; }
#IlfCutaway-{{ section.id }} .ict-comp { display: none; }
#IlfCutaway-{{ section.id }} .ict-comp.show {
  display: block;
  animation: ict-fadeup-{{ section.id }} .4s cubic-bezier(.25,.46,.45,.94);
}
@keyframes ict-fadeup-{{ section.id }} {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: none; }
}

/* ── Component number (ghost) ── */
#IlfCutaway-{{ section.id }} .ict-num {
  font-size: 40px; font-weight: 800; line-height: 1;
  color: rgba(255,255,255,.14); margin-bottom: 12px;
}

/* ── Component name ── */
#IlfCutaway-{{ section.id }} .ict-name {
  font-size: 23px; font-weight: 700; line-height: 1.2;
  color: #fff; margin-bottom: 12px;
}

/* ── Description ── */
#IlfCutaway-{{ section.id }} .ict-desc {
  font-size: 15px; line-height: 1.72; color: rgba(255,255,255,.55); margin: 0 0 22px;
}

/* ── Meta chips ── */
#IlfCutaway-{{ section.id }} .ict-meta {
  display: flex; flex-wrap: wrap; gap: 10px;
}
#IlfCutaway-{{ section.id }} .ict-meta span {
  font-size: 12px; font-weight: 600;
  color: #A7F432;
  background: rgba(167,244,50,.08);
  border: 1px solid rgba(167,244,50,.18);
  padding: 7px 12px; border-radius: 8px;
}

/* ── Nav dots ── */
#IlfCutaway-{{ section.id }} .ict-nav {
  display: flex; gap: 8px; margin-top: 30px;
}
#IlfCutaway-{{ section.id }} .ict-dot {
  flex: 1; height: 3px; border-radius: 3px;
  background: rgba(255,255,255,.12);
  cursor: pointer; transition: background .25s;
  border: none; padding: 0;
}
#IlfCutaway-{{ section.id }} .ict-dot.active {
  background: #A7F432;
}

/* ── Tablet: stack ── */
@media (max-width: 1023px) {
  #IlfCutaway-{{ section.id }} .ict-grid {
    grid-template-columns: 1fr;
    gap: 40px;
  }
}

/* ── Mobile ── */
@media (max-width: 639px) {
  #IlfCutaway-{{ section.id }} .ict-section { padding: 64px 0; }
  #IlfCutaway-{{ section.id }} .ict-container { padding: 0 16px; }
  #IlfCutaway-{{ section.id }} .ict-grid { margin-top: 40px; }
  #IlfCutaway-{{ section.id }} .ict-stage { padding: 16px; }
  #IlfCutaway-{{ section.id }} .ict-name { font-size: 19px; }
  #IlfCutaway-{{ section.id }} .ict-num { font-size: 32px; }
}
{% endstylesheet %}

<script>
(function () {
  var sid  = '{{ section.id }}';
  var root = document.getElementById('IlfCutaway-' + sid);
  if (!root) return;

  var comps    = root.querySelectorAll('.ict-comp');
  var hotspots = root.querySelectorAll('.ict-hs');
  var dots     = root.querySelectorAll('.ict-dot');

  function showComp(i) {
    comps.forEach(function (el, idx) { el.classList.toggle('show', idx === i); });
    hotspots.forEach(function (el, idx) { el.classList.toggle('active', idx === i); });
    dots.forEach(function (el, idx) { el.classList.toggle('active', idx === i); });
  }

  hotspots.forEach(function (btn) {
    btn.addEventListener('click',      function () { showComp(+btn.dataset.i); });
    btn.addEventListener('mouseenter', function () { showComp(+btn.dataset.i); });
  });

  dots.forEach(function (btn) {
    btn.addEventListener('click', function () { showComp(+btn.dataset.i); });
  });
})();
</script>

{% schema %}
{
  "name": "ILF Cutaway",
  "tag": "div",
  "settings": [
    { "type": "text",     "id": "eyebrow",     "label": "Eyebrow",     "default": "Inside the Fan" },
    { "type": "text",     "id": "heading",     "label": "Heading",     "default": "Tap a component to look inside." },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Six systems along the airflow path, from intake clamp to discharge spigot. Explore each one." }
  ],
  "blocks": [
    {
      "type": "component",
      "name": "Component",
      "settings": [
        { "type": "text",     "id": "num",   "label": "Number",      "default": "01" },
        { "type": "text",     "id": "name",  "label": "Name",        "default": "Mixed-Flow Impeller" },
        { "type": "textarea", "id": "desc",  "label": "Description", "default": "A backward-curved mixed-flow impeller blends centrifugal pressure with axial volume." },
        { "type": "text",     "id": "chip1", "label": "Chip 1",      "default": "High pressure + volume" },
        { "type": "text",     "id": "chip2", "label": "Chip 2",      "default": "Backward-curved blades" },
        { "type": "text",     "id": "chip3", "label": "Chip 3",      "default": "Statically & dynamically balanced" }
      ]
    }
  ],
  "presets": [
    {
      "name": "ILF Cutaway",
      "category": "Product",
      "blocks": [
        {
          "type": "component",
          "settings": {
            "num": "01", "name": "Mixed-Flow Impeller",
            "desc": "A backward-curved mixed-flow impeller blends centrifugal pressure with axial volume — moving far more air against duct resistance than a pure axial fan of the same diameter.",
            "chip1": "High pressure + volume", "chip2": "Backward-curved blades", "chip3": "Statically & dynamically balanced"
          }
        },
        {
          "type": "component",
          "settings": {
            "num": "02", "name": "External-Rotor EC Motor",
            "desc": "An electronically commutated motor delivers infinitely variable speed from 0–100% while drawing up to 50% less energy than an AC equivalent. Sealed maintenance-free bearings are rated to 40,000 hours.",
            "chip1": "EC brushless", "chip2": "0–100% modulation", "chip3": "40,000 h bearing life"
          }
        },
        {
          "type": "component",
          "settings": {
            "num": "03", "name": "Aerodynamic Guide Vanes",
            "desc": "Fixed stator vanes downstream of the impeller straighten the swirling discharge back into smooth axial flow, recovering static pressure and cutting turbulence-generated noise.",
            "chip1": "Pressure recovery", "chip2": "Flow straightening", "chip3": "Lower turbulence noise"
          }
        },
        {
          "type": "component",
          "settings": {
            "num": "04", "name": "Acoustic Composite Housing",
            "desc": "A double-skin housing wraps a sound-absorbing core in glass-reinforced polymer or galvanised steel, holding radiated breakout noise to whisper levels even at full duty.",
            "chip1": "Double-skin shell", "chip2": "Sound-absorbing core", "chip3": "GRP or galvanised steel"
          }
        },
        {
          "type": "component",
          "settings": {
            "num": "05", "name": "Wiring & Control Terminal",
            "desc": "An IP-rated terminal box accepts 0–10 V, PWM and Modbus inputs, and pairs with the Astberg app and Smart Panel for demand-based speed control and scheduling.",
            "chip1": "0–10 V · PWM · Modbus", "chip2": "App + Smart Panel", "chip3": "IP-rated enclosure"
          }
        },
        {
          "type": "component",
          "settings": {
            "num": "06", "name": "Quick-Release Mounting",
            "desc": "Tool-free spring clamps and rotatable feet let the fan drop straight into a duct run and mount at any angle — horizontal, vertical or inclined — in minutes.",
            "chip1": "Tool-free clamps", "chip2": "Any-angle mounting", "chip3": "Rotatable feet"
          }
        }
      ]
    }
  ]
}
{% endschema %}
