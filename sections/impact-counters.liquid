<div id="ImpactCounters-{{ section.id }}">
  <section class="ic-section">
    <div class="ic-glow" aria-hidden="true"></div>
    <div class="ic-container">

      <div class="ic-header">
        {% if section.settings.eyebrow != blank %}
          <p class="ic-eyebrow eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="ic-heading h2">{{ section.settings.heading }}</h2>
        {% endif %}
      </div>

      {% if section.blocks.size > 0 %}
        <div class="ic-grid" style="--ic-cols: {{ section.blocks.size }};">
          {% for block in section.blocks %}
            <div class="ic-card" {{ block.shopify_attributes }}>
              <div class="ic-value-row">
                <span class="ic-num metric-number text-gradient"
                  data-target="{{ block.settings.value }}"
                  data-dec="{{ block.settings.decimals }}">{{ block.settings.value }}</span>
                <span class="ic-suffix stat-label">{{ block.settings.suffix }}</span>
              </div>
              <p class="ic-label stat-label">{{ block.settings.label }}</p>
            </div>
          {% endfor %}
        </div>
      {% endif %}


    </div>
  </section>
</div>

{% stylesheet %}
/* ── Section ── */
#ImpactCounters-{{ section.id }} .ic-section {
  position: relative; overflow: hidden;
  background: #fff; padding: 96px 0;
}
#ImpactCounters-{{ section.id }} *, #ImpactCounters-{{ section.id }} *::before, #ImpactCounters-{{ section.id }} *::after { box-sizing: border-box; }

/* ── Lime glow ── */
#ImpactCounters-{{ section.id }} .ic-glow {
  pointer-events: none; position: absolute;
  left: 0; right: 0; top: -128px; z-index: 0;
  height: 384px;
  background: linear-gradient(to bottom, rgba(167,244,50,.10), transparent);
  filter: blur(48px);
}

/* ── Container ── */
#ImpactCounters-{{ section.id }} .ic-container {
  max-width: 1280px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 1;
}

/* ── Header ── */
#ImpactCounters-{{ section.id }} .ic-header { max-width: 768px; margin-bottom: 56px; }
#ImpactCounters-{{ section.id }} .ic-eyebrow {
  font-size: 10px; font-weight: 500; letter-spacing: .14em;
  text-transform: uppercase; color: #0E7A43; margin: 0 0 16px; line-height: 1;
}
#ImpactCounters-{{ section.id }} .ic-heading {
  font-size: clamp(30px, 4vw, 48px); font-weight: 600; line-height: 1.1;
  letter-spacing: -.025em; color: #111827; margin: 0;
}

/* ── Grid ── */
#ImpactCounters-{{ section.id }} .ic-grid {
  display: grid;
  grid-template-columns: repeat(var(--ic-cols, 4), 1fr);
  gap: 16px;
}

@media (max-width: 639px) {
  #ImpactCounters-{{ section.id }} .ic-grid {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior-x: contain;
    padding-bottom: 1rem;
    scrollbar-width: none;
    max-width: 100%;
  }
  #ImpactCounters-{{ section.id }} .ic-grid::-webkit-scrollbar { display: none; }
  #ImpactCounters-{{ section.id }} .ic-card {
    flex: 0 0 min(85vw, 20rem);
    scroll-snap-align: start;
  }
}

/* ── Card ── */
#ImpactCounters-{{ section.id }} .ic-card {
  border-radius: 16px;
  border: 1px solid #e5e7eb;
  background: #fff;
  padding: 32px;
  transition: opacity 0.6s ease, transform 0.6s ease;
}

/* ── Value row ── */
#ImpactCounters-{{ section.id }} .ic-value-row {
  display: flex; align-items: baseline; gap: 4px; margin-bottom: 16px;
}

/* ── Number (gradient text) ── */
#ImpactCounters-{{ section.id }} .ic-num {
  font-size: 48px; font-weight: 600; line-height: 1; letter-spacing: -.025em;
  background: linear-gradient(135deg, #0E7A43 0%, #00B26B 55%, #A7F432 100%);
  -webkit-background-clip: text; background-clip: text; color: transparent;
}

/* ── Suffix (M m³, GWh, t, +) ── */
#ImpactCounters-{{ section.id }} .ic-suffix {
  font-size: 24px; font-weight: 400; color: #9CA3AF; line-height: 1;
}

/* ── Label ── */
#ImpactCounters-{{ section.id }} .ic-label {
  font-size: 14px; line-height: 1.5; color: #6B7280; margin: 0;
}

/* ── Tablet: 2 cols ── */
@media (max-width: 1023px) {
  #ImpactCounters-{{ section.id }} .ic-grid { grid-template-columns: repeat(2, 1fr); }
}

/* ── Mobile ── */
@media (max-width: 639px) {
  #ImpactCounters-{{ section.id }} .ic-section { padding: 64px 0; }
  #ImpactCounters-{{ section.id }} .ic-container { padding: 0 var(--page-margin, 16px); }
  #ImpactCounters-{{ section.id }} .ic-header { margin-bottom: 36px; }
  #ImpactCounters-{{ section.id }} .ic-num { font-size: 40px; }
}
{% endstylesheet %}

<script>
(function () {
  var sid  = '{{ section.id }}';
  var root = document.getElementById('ImpactCounters-' + sid);
  if (!root) return;

  var cards = root.querySelectorAll('.ic-card');
  var nums  = root.querySelectorAll('.ic-num');

  /* ── counter animation ── */
  function animateCounter(el) {
    var target = parseFloat(el.dataset.target);
    var dec    = parseInt(el.dataset.dec, 10) || 0;
    var start  = performance.now();
    var dur    = 1800;
    function tick(now) {
      var p     = Math.min(1, (now - start) / dur);
      var eased = 1 - Math.pow(1 - p, 3);
      var val   = target * eased;
      el.textContent = val.toLocaleString('en-US', {
        minimumFractionDigits: dec,
        maximumFractionDigits: dec
      });
      if (p < 1) requestAnimationFrame(tick);
      else el.textContent = target.toLocaleString('en-US', {
        minimumFractionDigits: dec,
        maximumFractionDigits: dec
      });
    }
    requestAnimationFrame(tick);
  }

  function revealAll() {
    cards.forEach(function (c, i) {
      setTimeout(function () {
        c.style.opacity = '1';
        c.style.transform = 'none';
      }, i * 80);
    });
  }

  function setInitialHidden() {
    cards.forEach(function (c) {
      c.style.opacity = '0';
      c.style.transform = 'translateY(16px)';
    });
  }

  setInitialHidden();

  var revealDone = false;
  var safetyTimer = setTimeout(function () {
    if (!revealDone) { revealDone = true; revealAll(); }
  }, 1200);

  if ('IntersectionObserver' in window) {
    var revealObs = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (!entry.isIntersecting || revealDone) return;
        revealDone = true;
        clearTimeout(safetyTimer);
        revealAll();
        revealObs.disconnect();
      });
    }, { threshold: 0.15 });
    if (cards.length) revealObs.observe(cards[0]);

    var cntObs = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (!entry.isIntersecting) return;
        animateCounter(entry.target);
        cntObs.unobserve(entry.target);
      });
    }, { threshold: 0.4 });
    nums.forEach(function (el) { cntObs.observe(el); });

  } else {
    clearTimeout(safetyTimer);
    revealAll();
    nums.forEach(function (el) {
      var dec = parseInt(el.dataset.dec, 10) || 0;
      el.textContent = parseFloat(el.dataset.target).toLocaleString('en-US', {
        minimumFractionDigits: dec,
        maximumFractionDigits: dec
      });
    });
  }
})();
</script>

{% schema %}
{
  "name": "Impact Counters",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Sustainability Impact" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Real numbers. Real difference." }
  ],
  "blocks": [
    {
      "type": "counter",
      "name": "Counter",
      "settings": [
        { "type": "text", "id": "label",  "label": "Label",         "default": "Cleaner air delivered daily" },
        { "type": "text", "id": "value",  "label": "Value (number)","default": "2.4" },
        { "type": "text", "id": "suffix", "label": "Suffix",        "default": "M m³" },
        {
          "type": "select", "id": "decimals", "label": "Decimal places", "default": "1",
          "options": [
            { "value": "0", "label": "0  — e.g. 14,200" },
            { "value": "1", "label": "1  — e.g. 2.4" }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Impact Counters",
      "category": "Content",
      "blocks": [
        { "type": "counter", "settings": { "label": "Cleaner air delivered daily", "value": "2.4",  "suffix": "M m³", "decimals": "1" } },
        { "type": "counter", "settings": { "label": "Energy saved annually",        "value": "38",   "suffix": "GWh",  "decimals": "0" } },
        { "type": "counter", "settings": { "label": "CO₂ emissions avoided",        "value": "14200","suffix": "t",    "decimals": "0" } },
        { "type": "counter", "settings": { "label": "Healthier spaces equipped",    "value": "320",  "suffix": "+",    "decimals": "0" } }
      ]
    }
  ]
}
{% endschema %}
