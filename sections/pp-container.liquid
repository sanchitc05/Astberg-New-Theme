{% stylesheet %}
#CutawayDiagram-{{ section.id }} .cw-section {
  background: #111827;
  padding: 110px 0;
}
#CutawayDiagram-{{ section.id }} .cw-container {
  max-width: 1240px;
  margin: 0 auto;
  padding: 0 48px;
}
#CutawayDiagram-{{ section.id }} .cw-eyebrow {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: #A7F432;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 10px;
}
#CutawayDiagram-{{ section.id }} .cw-eyebrow::before {
  content: '';
  width: 26px;
  height: 1.5px;
  background: #A7F432;
  display: inline-block;
  flex-shrink: 0;
}
#CutawayDiagram-{{ section.id }} .cw-h2 {
  font-size: clamp(32px, 4vw, 54px);
  font-weight: 700;
  line-height: 1.1;
  letter-spacing: -.025em;
  color: #ffffff;
  margin-bottom: 18px;
}
#CutawayDiagram-{{ section.id }} .cw-lead {
  font-size: 17px;
  line-height: 1.75;
  color: rgba(255,255,255,.5);
  max-width: 620px;
}
#CutawayDiagram-{{ section.id }} .cw-cut-grid {
  display: grid;
  grid-template-columns: 1.45fr 1fr;
  gap: 50px;
  align-items: center;
  margin-top: 56px;
}
#CutawayDiagram-{{ section.id }} .cw-cut-stage {
  position: relative;
  background: rgba(255,255,255,.03);
  border: 1px solid rgba(255,255,255,.08);
  border-radius: 24px;
  padding: 30px;
}
#CutawayDiagram-{{ section.id }} .cw-hotspot {
  position: absolute;
  width: 30px;
  height: 30px;
  border-radius: 50%;
  background: #A7F432;
  color: #111827;
  border: none;
  cursor: pointer;
  font-size: 13px;
  font-weight: 800;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform .2s;
  z-index: 4;
}
#CutawayDiagram-{{ section.id }} .cw-hotspot::after {
  content: '';
  position: absolute;
  inset: -6px;
  border-radius: 50%;
  border: 1.5px solid rgba(167,244,50,.4);
  animation: cw-hsring 2.4s ease-out infinite;
}
@keyframes cw-hsring {
  0%   { transform: scale(.7);  opacity: .9; }
  100% { transform: scale(1.7); opacity:  0; }
}
#CutawayDiagram-{{ section.id }} .cw-hotspot:hover  { transform: scale(1.18); }
#CutawayDiagram-{{ section.id }} .cw-hotspot.active { background: #ffffff; transform: scale(1.18); }
#CutawayDiagram-{{ section.id }} .cw-hotspot.active::after { border-color: rgba(255,255,255,.5); }
#CutawayDiagram-{{ section.id }} .cw-cut-step {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: #A7F432;
  margin-bottom: 14px;
}
#CutawayDiagram-{{ section.id }} .cw-cut-panel { min-height: 200px; }
#CutawayDiagram-{{ section.id }} .cw-cut-comp { display: none; }
#CutawayDiagram-{{ section.id }} .cw-cut-comp.show {
  display: block;
  animation: cw-fadeUp .4s cubic-bezier(0.22,1,0.36,1);
}
@keyframes cw-fadeUp {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: none; }
}
#CutawayDiagram-{{ section.id }} .cw-cut-num  { font-size: 40px; font-weight: 800; line-height: 1; color: rgba(255,255,255,.14); margin-bottom: 12px; }
#CutawayDiagram-{{ section.id }} .cw-cut-name { font-size: 23px; font-weight: 700; line-height: 1.2; color: #ffffff; margin-bottom: 12px; }
#CutawayDiagram-{{ section.id }} .cw-cut-desc { font-size: 15px; line-height: 1.72; color: rgba(255,255,255,.55); margin-bottom: 22px; }
#CutawayDiagram-{{ section.id }} .cw-cut-meta { display: flex; flex-wrap: wrap; gap: 10px; }
#CutawayDiagram-{{ section.id }} .cw-cut-meta span {
  font-size: 12px;
  font-weight: 600;
  color: #A7F432;
  background: rgba(167,244,50,.08);
  border: 1px solid rgba(167,244,50,.18);
  padding: 7px 12px;
  border-radius: 8px;
}
#CutawayDiagram-{{ section.id }} .cw-cut-nav { display: flex; gap: 8px; margin-top: 30px; }
#CutawayDiagram-{{ section.id }} .cw-cut-dot {
  flex: 1;
  height: 3px;
  border-radius: 3px;
  background: rgba(255,255,255,.12);
  cursor: pointer;
  transition: background .25s;
  border: none;
  padding: 0;
}
#CutawayDiagram-{{ section.id }} .cw-cut-dot.active { background: #A7F432; }

/* Reveal */
#CutawayDiagram-{{ section.id }} .r { opacity: 1; transform: none; }

@media (max-width: 1000px) {
  #CutawayDiagram-{{ section.id }} .cw-container { padding: 0 36px; }
  #CutawayDiagram-{{ section.id }} .cw-cut-grid { grid-template-columns: 1fr; gap: 40px; }
}
@media (max-width: 820px) {
  #CutawayDiagram-{{ section.id }} .cw-section { padding: 76px 0; }
  #CutawayDiagram-{{ section.id }} .cw-h2 { font-size: clamp(28px, 6.6vw, 40px); }
  #CutawayDiagram-{{ section.id }} .cw-lead { font-size: 16px; }
}
@media (max-width: 560px) {
  #CutawayDiagram-{{ section.id }} .cw-container { padding: 0 22px; }
}
{% endstylesheet %}

<script>
(function () {
  var root = document.getElementById('CutawayDiagram-{{ section.id }}');
  if (!root) return;

  var COMPONENTS = [
    { num:'01', name:'Counter-Flow Polymer Core', desc:'A precision counter-flow heat exchanger transfers up to 96% of thermal energy and 78% of moisture between exhaust and supply air streams — without the two ever mixing.', meta:['96% thermal recovery','Enthalpy transfer','Antimicrobial polymer'] },
    { num:'02', name:'EC Supply Fan', desc:'Electronically commutated backward-curved impeller delivers constant-volume airflow while drawing a fraction of the power of conventional AC motors. Continuously modulated by the control board.', meta:['EC brushless motor','Constant-volume control','Up to 40% less energy'] },
    { num:'03', name:'EC Extract Fan', desc:'A matched extract fan maintains a balanced pressure regime across the building envelope, preventing draughts and uncontrolled infiltration.', meta:['Pressure-balanced','Independently trimmed','Whisper-quiet bearings'] },
    { num:'04', name:'F7 Supply Filter', desc:'ISO 16890 ePM1 70% filtration captures fine particles, pollen and combustion soot before fresh air ever reaches the occupied space.', meta:['ISO ePM1 70%','PM2.5 capture','Tool-free replacement'] },
    { num:'05', name:'Summer Bypass Damper', desc:'A motorised 100% bypass routes cool night air straight past the core for free-cooling, automatically engaging when outdoor conditions allow.', meta:['100% modulating','Automatic free-cooling','Frost-protection logic'] },
    { num:'06', name:'Smart Control Board', desc:'On-board intelligence with CO₂, humidity and temperature inputs. Native Modbus & BACnet, plus the Astberg app for scheduling, monitoring and OTA updates.', meta:['Modbus / BACnet','CO₂ + RH demand control','App + OTA updates'] }
  ];

  function showComp(i) {
    root.querySelectorAll('.cw-cut-comp').forEach(function (el, idx) { el.classList.toggle('show', idx === i); });
    root.querySelectorAll('.cw-hotspot').forEach(function (el, idx) { el.classList.toggle('active', idx === i); });
    root.querySelectorAll('.cw-cut-dot').forEach(function (el, idx) { el.classList.toggle('active', idx === i); });
  }

  var panel = root.querySelector('#cw-cutPanel-{{ section.id }}');
  if (panel) {
    panel.innerHTML = COMPONENTS.map(function (c, i) {
      return '<div class="cw-cut-comp' + (i === 0 ? ' show' : '') + '">' +
        '<div class="cw-cut-num">' + c.num + '</div>' +
        '<div class="cw-cut-name">' + c.name + '</div>' +
        '<div class="cw-cut-desc">' + c.desc + '</div>' +
        '<div class="cw-cut-meta">' + c.meta.map(function (m) { return '<span>' + m + '</span>'; }).join('') + '</div>' +
        '</div>';
    }).join('');
  }

  var dots = root.querySelector('#cw-cutDots-{{ section.id }}');
  if (dots) {
    dots.innerHTML = COMPONENTS.map(function (_, i) {
      return '<button class="cw-cut-dot' + (i === 0 ? ' active' : '') + '" data-i="' + i + '" aria-label="Component ' + (i + 1) + '"></button>';
    }).join('');
    dots.querySelectorAll('.cw-cut-dot').forEach(function (d) {
      d.addEventListener('click', function () { showComp(+d.dataset.i); });
    });
  }

  root.querySelectorAll('.cw-hotspot').forEach(function (h, i) {
    h.addEventListener('click', function () { showComp(i); });
    h.addEventListener('mouseenter', function () { showComp(i); });
  });

  showComp(0);
})();
</script>

{% schema %}
{
  "name": "Cutaway Diagram",
  "tag": "div",
  "settings": [
    { "type": "text",     "id": "eyebrow",    "label": "Eyebrow",    "default": "Inside the unit" },
    { "type": "text",     "id": "heading",    "label": "Heading",    "default": "Tap a component to look inside." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Six precision systems working as one. Explore each part of the airflow path through the Series Pro." }
  ],
  "presets": [
    {
      "name": "Cutaway Diagram",
      "category": "Product"
    }
  ]
}
{% endschema %}
