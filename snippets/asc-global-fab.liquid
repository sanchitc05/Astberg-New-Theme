    <!-- Header -->
    <div id="ascg-header">
      <div class="ascg-hdtop">
        <div id="ascg-logo">
          <img src="https://www.astbergventilation.com/images/logo.webp" alt="Astberg Ventilation" onerror="this.style.display='none'">
        </div>
        <button id="ascg-close" aria-label="Close">✕</button>
      </div>
      <h2 class="ascg-title">Duct Fan Size Calculator</h2>
      <p class="ascg-sub">Find the perfect ventilation solution for your space</p>
      <div class="ascg-dots">
        <div class="ascg-dot ascg-on" id="ascg-dot1"></div>
        <div class="ascg-dot" id="ascg-dot2"></div>
      </div>
    </div>

    <!-- Body -->
    <div id="ascg-body">

      <!-- Step 1 -->
      <div class="ascg-panel" id="ascg-p1">
        <span class="ascg-lbl">Unit of Measurement</span>
        <div class="ascg-pills" id="ascg-pills">
          <button class="ascg-pill ascg-on" data-unit="feet">Feet</button>
          <button class="ascg-pill" data-unit="meter">Meter</button>
          <button class="ascg-pill" data-unit="centimeter">Cm</button>
          <button class="ascg-pill" data-unit="inches">Inch</button>
          <button class="ascg-pill" data-unit="mm">Mm</button>
        </div>
        <span class="ascg-dimlbl" id="ascg-dimlbl">Room Dimensions (feet)</span>
        <div class="ascg-dims">
          <div class="ascg-field"><div class="ascg-flbl">L</div><input class="ascg-num" id="ascg-l" type="number" min="0" step="0.1" placeholder="0"></div>
          <span class="ascg-sep">×</span>
          <div class="ascg-field"><div class="ascg-flbl">W</div><input class="ascg-num" id="ascg-w" type="number" min="0" step="0.1" placeholder="0"></div>
          <span class="ascg-sep">×</span>
          <div class="ascg-field"><div class="ascg-flbl">H</div><input class="ascg-num" id="ascg-h" type="number" min="0" step="0.1" placeholder="0"></div>
        </div>
        <span class="ascg-lbl">Air Changes Per Hour (ACPH)</span>
        <div class="ascg-acphrow">
          <input class="ascg-acphinput" id="ascg-acph" type="number" min="0" step="0.1" placeholder="Type or pick room type →">
          <button class="ascg-roombtn" id="ascg-room-open">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            Room Type
          </button>
        </div>
        <button class="ascg-calcbtn" id="ascg-calcbtn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 7H7a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2V9a2 2 0 00-2-2h-2M9 7V5a2 2 0 012-2h2a2 2 0 012 2v2M9 7h6M12 11v6M9 14h6"/></svg>
          Calculate CMH &amp; CFM
        </button>
        <div class="ascg-tncrow"><button class="ascg-tnclink" id="ascg-tnc-open">Terms &amp; Conditions</button></div>
      </div>

      <!-- Step 2 -->
      <div class="ascg-panel ascg-hide" id="ascg-p2">
        <div class="ascg-rboxes">
          <div class="ascg-rbox"><div class="ascg-runit">CMH</div><div class="ascg-rval" id="ascg-cmh">—</div><div class="ascg-rdesc">m³ per hour</div></div>
          <div class="ascg-rbox"><div class="ascg-runit">CFM</div><div class="ascg-rval" id="ascg-cfm">—</div><div class="ascg-rdesc">ft³ per minute</div></div>
        </div>
        <div class="ascg-prodhead"><span>Recommended Products</span><div class="ascg-prodline"></div></div>
        <div class="ascg-tagwrap ascg-hide" id="ascg-tagwrap"><div class="ascg-tagrow" id="ascg-tagrow"></div></div>
        <div class="ascg-prodgrid" id="ascg-prodgrid"></div>
        <button class="ascg-recalcbtn" id="ascg-recalc">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 102.13-9.36L1 10"/></svg>
          Recalculate
        </button>
      </div>

    </div>
  </div>
</div>

<script>
(function () {
  'use strict';

  var FANS = window.ascGFans || [];
  var TAGS = window.ascGTags || [];
  var UNIT_F = { feet:1, meter:3.28084, centimeter:0.0328084, inches:0.0833333, mm:0.00328084 };
  var UNIT_N = { feet:'feet', meter:'meters', centimeter:'centimeters', inches:'inches', mm:'millimeters' };

  var overlay   = document.getElementById('ascg-overlay');
  var closeBtn  = document.getElementById('ascg-close');
  var sheetBg   = document.getElementById('ascg-sheetbg');
  var roomOpen  = document.getElementById('ascg-room-open');
  var tncWrap   = document.getElementById('ascg-tnc');
  var tncOpen   = document.getElementById('ascg-tnc-open');
  var tncClose  = document.getElementById('ascg-tnc-close');
  var p1        = document.getElementById('ascg-p1');
  var p2        = document.getElementById('ascg-p2');
  var dot1      = document.getElementById('ascg-dot1');
  var dot2      = document.getElementById('ascg-dot2');
  var dimLbl    = document.getElementById('ascg-dimlbl');
  var cmhEl     = document.getElementById('ascg-cmh');
  var cfmEl     = document.getElementById('ascg-cfm');
  var prodGrid  = document.getElementById('ascg-prodgrid');
  var tagWrap   = document.getElementById('ascg-tagwrap');
  var tagRow    = document.getElementById('ascg-tagrow');
  var pillsWrap = document.getElementById('ascg-pills');
  var calcBtn   = document.getElementById('ascg-calcbtn');
  var recalcBtn = document.getElementById('ascg-recalc');

  var activeUnit = 'feet';
  var matchedFans = [];
  var activeTag = 'all';

  function openModal() {
    overlay.classList.add('ascg-on');
    document.body.style.overflow = 'hidden';
  }
  function closeModal() {
    overlay.classList.remove('ascg-on');
    document.body.style.overflow = '';
  }

  closeBtn.addEventListener('click', closeModal);
  overlay.addEventListener('click', function (e) { if (e.target === overlay) closeModal(); });
  document.addEventListener('keydown', function (e) {
    if (e.key !== 'Escape') return;
    if (sheetBg.classList.contains('ascg-on')) { sheetBg.classList.remove('ascg-on'); }
    else if (tncWrap.classList.contains('ascg-on')) { tncWrap.classList.remove('ascg-on'); }
    else { closeModal(); }
  });

  pillsWrap.querySelectorAll('.ascg-pill').forEach(function (pill) {
    pill.addEventListener('click', function () {
      pillsWrap.querySelectorAll('.ascg-pill').forEach(function (p) { p.classList.remove('ascg-on'); });
      pill.classList.add('ascg-on');
      activeUnit = pill.dataset.unit;
      dimLbl.textContent = 'Room Dimensions (' + UNIT_N[activeUnit] + ')';
    });
  });

  roomOpen.addEventListener('click', function () { sheetBg.classList.add('ascg-on'); });
  sheetBg.addEventListener('click', function (e) { if (e.target === sheetBg) sheetBg.classList.remove('ascg-on'); });
  sheetBg.querySelectorAll('.ascg-rcard').forEach(function (card) {
    card.addEventListener('click', function () {
      document.getElementById('ascg-acph').value = card.dataset.acph;
      sheetBg.classList.remove('ascg-on');
    });
  });

  tncOpen.addEventListener('click', function () { tncWrap.classList.add('ascg-on'); });
  tncClose.addEventListener('click', function () { tncWrap.classList.remove('ascg-on'); });

  calcBtn.addEventListener('click', function () {
    var l  = parseFloat(document.getElementById('ascg-l').value);
    var w  = parseFloat(document.getElementById('ascg-w').value);
    var h  = parseFloat(document.getElementById('ascg-h').value);
    var ac = parseFloat(document.getElementById('ascg-acph').value);
    if ([l, w, h, ac].some(function (v) { return isNaN(v) || v <= 0; })) {
      alert('Please fill in all four fields with valid positive numbers.');
      return;
    }
    var f = UNIT_F[activeUnit] || 1;
    var cfm = (l*f) * (w*f) * (h*f) * ac / 60;
    var cmh = cfm * 1.7;
    p1.classList.add('ascg-hide'); p2.classList.remove('ascg-hide');
    dot1.classList.remove('ascg-on'); dot2.classList.add('ascg-on');
    overlay.scrollTop = 0;
    countUp(cmhEl, cmh, 650);
    countUp(cfmEl, cfm, 650);
    renderProducts(cmh);
  });

  recalcBtn.addEventListener('click', function () {
    p2.classList.add('ascg-hide'); p1.classList.remove('ascg-hide');
    dot2.classList.remove('ascg-on'); dot1.classList.add('ascg-on');
  });

  function countUp(el, end, dur) {
    var start = null;
    (function step(ts) {
      if (!start) start = ts;
      var p = Math.min((ts-start)/dur, 1);
      el.textContent = ((1-Math.pow(1-p,3))*end).toFixed(2);
      if (p < 1) requestAnimationFrame(step);
    })(performance.now());
  }

  function parseTags(raw) {
    return (raw||'').split(',').map(function(t){return t.trim().toLowerCase();}).filter(Boolean);
  }

  function renderProducts(cmh) {
    matchedFans = FANS.filter(function(f){ return cmh >= f.minCmh && cmh <= f.maxCmh; });
    activeTag = 'all';
    renderTagFilters();
    renderGrid();
  }

  function renderTagFilters() {
    var used = {};
    matchedFans.forEach(function(f){ parseTags(f.tags).forEach(function(t){ used[t]=true; }); });
    var present = TAGS.filter(function(t){ return used[t.value]; });
    if (!present.length) { tagWrap.classList.add('ascg-hide'); return; }
    tagWrap.classList.remove('ascg-hide');
    tagRow.innerHTML = '<button class="ascg-tagpill' + (activeTag==='all'?' ascg-on':'') + '" data-tag="all">All</button>'
      + present.map(function(t){ return '<button class="ascg-tagpill' + (activeTag===t.value?' ascg-on':'') + '" data-tag="'+t.value+'">'+esc(t.label)+'</button>'; }).join('');
    tagRow.querySelectorAll('.ascg-tagpill').forEach(function(pill){
      pill.addEventListener('click', function(){ activeTag = pill.dataset.tag; renderTagFilters(); renderGrid(); });
    });
  }

  function renderGrid() {
    var show = activeTag === 'all' ? matchedFans : matchedFans.filter(function(f){ return parseTags(f.tags).indexOf(activeTag) !== -1; });
    if (!show.length) {
      prodGrid.innerHTML = '<div class="ascg-noprod"><svg width="38" height="38" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin:0 auto 10px;display:block"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg><p>' + (matchedFans.length ? 'No products for this filter.' : 'No products match this CMH range.') + '</p></div>';
      return;
    }
    prodGrid.innerHTML = show.map(function(fan){
      var badge = fan.badge ? '<span class="ascg-pbadge">'+fan.badge+'</span>' : '';
      var img   = fan.image ? '<img class="ascg-pimg" src="'+fan.image+'" alt="'+esc(fan.name)+'" loading="lazy">' : '<div class="ascg-pimgph"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div>';
      var cta   = fan.url ? '<span class="ascg-pshop">Shop Now <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>' : '';
      var tag   = fan.url ? 'a' : 'div';
      var attr  = fan.url ? 'href="'+fan.url+'" target="_blank" rel="noopener noreferrer"' : '';
      return '<'+tag+' class="ascg-pcard" '+attr+'>'+badge+img+'<div class="ascg-pname">'+esc(fan.name)+'</div>'+cta+'</'+tag+'>';
    }).join('');
  }

  function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

  /* ── FAB ── */
  var fabWrap = document.getElementById('ascg-fabwrap');

  /* If the section's FAB is already on this page, hide global one and stop */
  if (document.querySelector('[id^="asc-fabwrap-"]')) {
    if (fabWrap) fabWrap.style.display = 'none';
    return;
  }

  var fabBtn = document.getElementById('ascg-fab');
  var fabX   = document.getElementById('ascg-fabx');

  var offX=0, offY=0, dSX, dSY, dSOX, dSOY, dragging=false, didMove=false;

  function gc(e) { return e.touches ? e.touches[0] : e; }

  fabWrap.addEventListener('mousedown',  down);
  fabWrap.addEventListener('touchstart', down, { passive:false });

  function down(e) {
    if (e.target === fabX || fabX.contains(e.target)) return;
    dragging=true; didMove=false;
    var c=gc(e); dSX=c.clientX; dSY=c.clientY; dSOX=offX; dSOY=offY;
    fabWrap.classList.add('ascg-dragging');
    e.preventDefault();
  }

  document.addEventListener('mousemove',  move);
  document.addEventListener('touchmove',  move, { passive:false });

  function move(e) {
    if (!dragging) return;
    var c=gc(e), dx=c.clientX-dSX, dy=c.clientY-dSY;
    if (Math.abs(dx)>4||Math.abs(dy)>4) didMove=true;
    offX=dSOX+dx; offY=dSOY+dy;
    fabWrap.style.transform='translate('+offX+'px,'+offY+'px)';
    e.preventDefault();
  }

  document.addEventListener('mouseup',  up);
  document.addEventListener('touchend', up);

  function up() { if(!dragging)return; dragging=false; fabWrap.classList.remove('ascg-dragging'); }

  fabBtn.addEventListener('click', function() {
    if (didMove) { didMove=false; return; }
    openModal();
  });
  /* touchstart preventDefault (needed for drag) cancels the click event on mobile.
     Handle tap via touchend instead. */
  fabBtn.addEventListener('touchend', function(e) {
    if (didMove) { didMove=false; return; }
    if (e.target === fabX || fabX.contains(e.target)) return;
    e.preventDefault();
    openModal();
  });

  fabX.addEventListener('click', function(e) {
    e.stopPropagation();
    fabWrap.classList.add('ascg-gone');
  });
  fabX.addEventListener('keydown', function(e) {
    if (e.key==='Enter'||e.key===' ') { e.preventDefault(); fabX.click(); }
  });

})();
</script>
